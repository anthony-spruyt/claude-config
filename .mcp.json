{
  "mcpServers": {
    "agentmemory": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@agentmemory/mcp"],
      "env": {
        "AGENTMEMORY_URL": "${AGENTMEMORY_URL}",
        "AGENTMEMORY_SECRET": "${AGENTMEMORY_SECRET}"
      }
    },
    "bravesearch": {
      "type": "http",
      "url": "https://brave-search-mcp.lan.${EXTERNAL_DOMAIN}/mcp",
      "headers": {
        "X-API-KEY": "${BRAVE_SEARCH_MCP_API_KEY}"
      }
    }
  }
}
