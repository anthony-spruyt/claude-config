# n8n workflow templates contain {{ variable }} syntax that creates invalid URLs
# GitHub API URLs require authentication and can't be validated
https://api.github.com/.*

# conventionalcommits.org has intermittent SSL issues in CI
https://www.conventionalcommits.org/.*

# Shell variables in workflow files get URL-encoded as %7B (for {)
.*%7B.*

# GitHub rate-limits unauthenticated requests (429 Too Many Requests)
https://github.com/.*
https://raw.githubusercontent.com/.*
